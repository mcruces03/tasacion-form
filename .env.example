# --- En Render (recomendado): Resend evita el "Connection timeout" de Gmail ---
# Crea una API key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Remitente (por defecto usa onboarding@resend.dev; si verificas dominio en Resend, pon tu email aquí)
# EMAIL_FROM=Valoración <noreply@tudominio.com>

# --- En local: Nodemailer (Gmail) ---
# Para Gmail: Contraseña de aplicación https://myaccount.google.com/apppasswords
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
