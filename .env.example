# Server: envío por email con Nodemailer (SMTP)
# Usa tu email como remitente. Para Gmail, crea una "Contraseña de aplicación":
# https://myaccount.google.com/apppasswords
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion

# Opcional: otro servidor SMTP (por defecto usa Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
