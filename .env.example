# --- En Render: enviar desde tu Gmail (sin dominio, sin Resend) ---
# Crea credenciales OAuth2 en Google Cloud y obtén el refresh token con:
#   node scripts/get-gmail-oauth-token.js
# Luego en Render → Environment añade:
EMAIL_USER=tu_gmail@gmail.com
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxxx
GMAIL_REFRESH_TOKEN=xxxx

# --- Alternativa: Resend (si verificas dominio puedes enviar a cualquiera) ---
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=Valoracion <noreply@tudominio.com>

# --- En local: Gmail con contraseña de aplicación ---
# EMAIL_USER=tu_email@gmail.com
# EMAIL_PASS=tu_contraseña_de_aplicacion
